# =====================================================
# 「教えて、minta先生」用 環境変数テンプレ
# =====================================================
# このファイルをコピーして .env.local を作成し、各値を埋める。
#   cp .env.local.example .env.local
#
# ⚠️ .env.local は絶対に Git にコミットしない（.gitignore で除外済）
# ⚠️ シークレットは Claude や ChatGPT のチャットに貼らない（事故ります）
# =====================================================

# --- OpenAI ---
# 取得元: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase ---
# 取得元: Supabase プロジェクト → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
